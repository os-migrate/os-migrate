---
skip_list:
  - 'line-length'  # Lines should be no longer than 120 chars
  - 'yaml[line-length]'  # Long Jinja one-liners required for jinja[spacing] compliance
  - 'var-naming[no-role-prefix]'  # Variables names from within roles should use role_name_ as a prefix
exclude_paths:
  - ".ansible/"
  - "tests/"
  - ".venv/"
  - "plugins/modules/_vendor/"
  # Vendored OpenStack modules (symlinked from openstack.cloud at build time)
  - "plugins/modules/auth.py"
  - "plugins/modules/compute_flavor.py"
  - "plugins/modules/compute_flavor_info.py"
  - "plugins/modules/floating_ip.py"
  - "plugins/modules/identity_domain.py"
  - "plugins/modules/identity_role.py"
  - "plugins/modules/identity_user.py"
  - "plugins/modules/identity_user_info.py"
  - "plugins/modules/image.py"
  - "plugins/modules/image_info.py"
  - "plugins/modules/keypair.py"
  - "plugins/modules/network.py"
  - "plugins/modules/networks_info.py"
  - "plugins/modules/port.py"
  - "plugins/modules/project.py"
  - "plugins/modules/project_info.py"
  - "plugins/modules/role_assignment.py"
  - "plugins/modules/router.py"
  - "plugins/modules/security_group.py"
  - "plugins/modules/security_group_rule.py"
  - "plugins/modules/server.py"
  - "plugins/modules/server_action.py"
  - "plugins/modules/server_info.py"
  - "plugins/modules/server_volume.py"
  - "plugins/modules/subnet.py"
  - "plugins/modules/subnets_info.py"
  - "plugins/modules/volume.py"
  - "plugins/modules/volume_info.py"
  - "plugins/module_utils/openstack.py"
  - "plugins/module_utils/ironic.py"

# When vendor symlinks are not materialized in the checkout,
# ansible-lint cannot resolve these collection modules.
mock_modules:
  - os_migrate.os_migrate.auth
  - os_migrate.os_migrate.compute_flavor
  - os_migrate.os_migrate.compute_flavor_info
  - os_migrate.os_migrate.floating_ip
  - os_migrate.os_migrate.identity_domain
  - os_migrate.os_migrate.identity_role
  - os_migrate.os_migrate.identity_user
  - os_migrate.os_migrate.identity_user_info
  - os_migrate.os_migrate.image
  - os_migrate.os_migrate.image_info
  - os_migrate.os_migrate.keypair
  - os_migrate.os_migrate.network
  - os_migrate.os_migrate.networks_info
  - os_migrate.os_migrate.port
  - os_migrate.os_migrate.project
  - os_migrate.os_migrate.project_info
  - os_migrate.os_migrate.role_assignment
  - os_migrate.os_migrate.router
  - os_migrate.os_migrate.security_group
  - os_migrate.os_migrate.security_group_rule
  - os_migrate.os_migrate.server
  - os_migrate.os_migrate.server_action
  - os_migrate.os_migrate.server_info
  - os_migrate.os_migrate.server_volume
  - os_migrate.os_migrate.subnet
  - os_migrate.os_migrate.subnets_info
  - os_migrate.os_migrate.volume
  - os_migrate.os_migrate.volume_info

# This is a workaround, we need to port ansible files to 2.17.x
profile: 'production'
